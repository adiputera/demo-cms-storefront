# Environment variables for local development
# Copy this file to .env.local and adjust values as needed

# Database Configuration
DATABASE_URL=jdbc:postgresql://localhost:5432/headless_cms
DATABASE_USERNAME=cms_user
DATABASE_PASSWORD=cms_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Backend Ports
STOREFRONT_BACKEND_PORT=8080
CMS_BACKEND_PORT=8081

# Frontend Configuration
NEXT_PUBLIC_STOREFRONT_API_URL=http://localhost:8080
NEXT_PUBLIC_CMS_API_URL=http://localhost:8081

# Logging
LOG_LEVEL=DEBUG
JPA_SHOW_SQL=true
